# Shared MLflow settings
MLFLOW_TRACKING_URI=http://127.0.0.1:8080
MLFLOW_EXPERIMENT_NAME=TennisVision

# Shared runtime settings
DEVICE=auto

# Shot classification API model source
# Use either MODEL_URI or RUN_ID.
MODEL_URI=models:/TennisVision@champion
RUN_ID=
MODEL_NAME=mobilenet_v3_large

# Detection API model source
# MLflow source has priority. Use either DETECTION_MODEL_URI or DETECTION_RUN_ID.
# If both are empty, the API uses DETECTION_MODEL_PATH for local development.
DETECTION_MODEL_URI=
DETECTION_RUN_ID=
DETECTION_MODEL_ARTIFACT_PATH=models/best.pt
DETECTION_MODEL_PATH=data/artifacts/detection/yolo11n_baseline/weights/best.pt

# Detection inference defaults
DETECTION_BACKEND=ultralytics
DETECTION_IMGSZ=960
DETECTION_CONFIDENCE=0.25
DETECTION_IOU=0.7
